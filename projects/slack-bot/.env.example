# このリポジトリのボットは projects/slack-bot/ から起動する。
# 環境変数は「このディレクトリ」の .env に置く（members/leader/.env は自動では読まれません）。
# 初回: cp .env.example .env して、下記の空欄に Slack / LLM の値を入れてください。
#
# Slack App（必須）
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-

# サーバ（Cloud Run 等の PORT を渡す想定。Socket Mode では未使用）
PORT=3000

# --- Socket Mode（任意）— 設定すると 公開URL・ngrok 不要。アプリ管理で App Level Token (connections:write) を発行
# SLACK_APP_TOKEN=xapp-1-...

# スキル本文のプロンプト上限（トークン節約）
# SKILL_PROMPT_MAX_CHARS=12000

# LLM（いずれか1系統を有効化）
# openai または anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=
# 省略時 gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=（LLM_PROVIDER=anthropic のとき必須）
# ANTHROPIC_MODEL=claude-opus-4-6
