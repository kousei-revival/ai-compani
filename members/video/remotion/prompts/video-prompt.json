{
  "description": "新規バージョン: 生成した背景画像・BGM を組み合わせた 10 秒動画",
  "fps": 30,
  "width": 1920,
  "height": 1080,
  "bgm": {
    "src": "audio/bgm.wav",
    "volume": 0.32,
    "loop": true
  },
  "scenes": [
    {
      "durationSeconds": 2.5,
      "backgroundColor": "#0f172a",
      "backgroundImage": "images/scene-intro.png",
      "backgroundImageFit": "cover",
      "backgroundDim": 0.35,
      "elements": [
        {
          "text": "はじめまして、ようこそ",
          "color": "#F8FAFC",
          "fontSize": 76
        }
      ]
    },
    {
      "durationSeconds": 5,
      "backgroundColor": "#FFF7ED",
      "backgroundImage": "images/scene-main.png",
      "backgroundImageFit": "cover",
      "backgroundDim": 0.15,
      "gap": 28,
      "elements": [
        {
          "type": "image",
          "src": "images/badge-focus.png",
          "maxHeight": 220,
          "borderRadius": 16
        },
        {
          "text": "今日は「伝え方」のコツを3つだけ",
          "color": "#1C1917",
          "fontSize": 64,
          "marginTop": 36
        }
      ]
    },
    {
      "durationSeconds": 2.5,
      "backgroundColor": "#4C1D95",
      "backgroundImage": "images/scene-outro.png",
      "backgroundImageFit": "cover",
      "backgroundDim": 0.25,
      "elements": [
        {
          "text": "最後まで見てくれてありがとう",
          "color": "#FAF5FF",
          "fontSize": 64
        },
        {
          "text": "チャンネル登録・高評価お願いします",
          "color": "#EDE9FE",
          "fontSize": 40,
          "marginTop": 100
        }
      ]
    }
  ]
}
